[package]
name = "jetdb"
version = "0.1.1"
edition = "2021"
license = "MIT OR Apache-2.0"
description = "Pure Rust library for reading Microsoft Access (.mdb/.accdb) files"
repository = "https://github.com/dominion525/jetdb"
readme = "../../README.md"
keywords = ["access", "mdb", "accdb", "jet", "database"]
categories = ["database", "parser-implementations"]
rust-version = "1.82"
exclude = ["testdata/", "AGENTS*", "CLAUDE*", ".claude/"]

[dependencies]
cfb = "0.14"
log = "0.4"
ovba = "0.7"
